# onnxruntime-node 1.22.0 has a broken Linux x64 postinstall manifest that
# tries to extract CUDA provider .so files from win-x64 paths in the NuGet
# package, which makes `npm ci` fail before the repo can even build or test.
# Skip the extra installer by default so dependency installation succeeds on
# Linux dev/test machines. The base package still installs normally.
onnxruntime_node_install=skip
